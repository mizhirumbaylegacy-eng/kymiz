# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard/project/vhfoatqqpchfkceqdqxv/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://vhfoatqqpchfkceqdqxv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Settings > API > Project API keys > anon/public

# Supabase Service Role (server-only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=              # Settings > API > Project API keys > service_role

# Database direct connection (for migrations via CLI)
# postgresql://postgres:[YOUR-PASSWORD]@db.vhfoatqqpchfkceqdqxv.supabase.co:5432/postgres
DATABASE_URL=

# Supabase CLI auth (for db:types, db:push, db:pull)
# Run: npx supabase login  →  generates a token at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Anthropic Claude API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# For local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# LinkedIn OAuth — https://www.linkedin.com/developers/apps
# Register redirect URI: {APP_URL}/api/linkedin/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Stripe Price IDs — Stripe Dashboard → Products → [plan] → Price ID
STARTER_PRICE_ID=price_...
PRO_PRICE_ID=price_...
AGENCY_PRICE_ID=price_...
